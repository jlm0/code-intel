{
  "name": "code-intel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first JS/TS code intelligence graph CLI and MCP server.",
  "bin": {
    "code-intel": "./dist/cli/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:cli": "vitest run tests/cli",
    "test:mcp": "vitest run tests/mcp",
    "test:pty": "vitest run tests/pty",
    "test:e2e": "vitest run tests/e2e",
    "eval": "node dist/cli/main.js eval"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@c4312/scip": "0.1.0",
    "@huggingface/transformers": "4.2.0",
    "@ladybugdb/core": "0.16.1",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@sourcegraph/scip-typescript": "0.4.0",
    "commander": "14.0.3",
    "tree-sitter": "0.21.1",
    "tree-sitter-javascript": "0.21.4",
    "tree-sitter-typescript": "0.23.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "execa": "9.6.1",
    "node-pty": "1.1.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
