{
  "schemaVersion": "code-intel.eval-pack.v1",
  "id": "oss-rallly-adversarial",
  "name": "Rallly OSS Adversarial Extension",
  "version": "1.0.0",
  "kind": "external-git",
  "description": "Adversarial extension that re-uses the Rallly pinned corpus to attack stricter AST detail, evidence-tight graph edges, multi-package boundary traversal, type-only imports, mock-derived test linking, and ranking precision on real code.",
  "license": "AGPL-3.0",
  "corpus": {
    "type": "git",
    "url": "https://github.com/lukevella/rallly.git",
    "ref": "5017e6a3a616bf479ee21ca74d86d0da85e1a169",
    "repoPaths": ["."],
    "sparsePaths": [
      "apps/api/package.json",
      "apps/api/src/**",
      "apps/web/package.json",
      "apps/web/src/app/[locale]/(optional-space)/poll/**",
      "apps/web/src/app/[locale]/(space)/(dashboard)/polls/**",
      "apps/web/src/app/api/private/**",
      "apps/web/tests/**",
      "packages/api-core/package.json",
      "packages/api-core/src/**",
      "packages/billing/package.json",
      "packages/billing/src/**",
      "packages/database/package.json",
      "packages/database/src/**",
      "packages/ui/package.json",
      "packages/ui/src/**",
      "package.json",
      "pnpm-workspace.yaml",
      "tsconfig.json"
    ]
  },
  "caseFiles": ["cases/adversarial-queries.json"],
  "astCaseFiles": ["cases/adversarial-ast.json"],
  "graphCaseFiles": ["cases/adversarial-graph.json"]
}
